// Problem: GCD of Strings
// Platform: LeetCode
// Approach: Check concatenation compatibility, then use gcd of lengths
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <numeric>
class Solution {
public:
    string gcdOfStrings(string str1, string str2) {
        
        if(str1 + str2 != str2 + str1)
            return "";

        int l1=str1.length();
        int l2=str2.length();

        int gcd_length = gcd(l1,l2);
        
        return str1.substr(0, gcd_length);
        
    }
};
