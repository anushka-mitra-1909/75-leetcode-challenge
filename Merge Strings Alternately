// Problem: Merge Strings Alternately
// Platform: LeetCode
// Approach: Traverse both strings using a single loop and append characters alternately
// Time Complexity: O(n)
// Space Complexity: O(n)

class Solution {
public:
    string mergeAlternately(string word1, string word2) {
        string res="";
        int i;
        int l=max(word1.length(), word2.length());
        for(i=0 ; i<l; i++){
            if(i<word1.length()) 
                res+=word1[i];
            if(i<word2.length()) 
                res+=word2[i];
        }

        return res;
    }
};
