// Problem: Can Place Flowers
// Platform: LeetCode
// Approach: Greedy
// - Traverse the flowerbed and check for valid planting positions
// - A flower can be planted if current, left, and right positions are empty
// - Treat boundaries (start/end) as empty if neighbors don't exist
// - Plant the flower, decrement n, and skip next index (no adjacent planting)
// Time Complexity: O(n)
// Space Complexity: O(1)

class Solution {
public:
    bool canPlaceFlowers(vector<int>& flowerbed, int n) {
        
        int size = flowerbed.size();
        int i = 0;

        while(i < size) {
            
            // Check if current plot is empty
            if(flowerbed[i] == 0) {

                // Check if left and right plots are empty or out of bounds
                bool leftEmpty = (i == 0) || (flowerbed[i - 1] == 0);
                bool rightEmpty = (i == size - 1) || (flowerbed[i + 1] == 0);

                // If both sides are empty, we can plant a flower here
                if(leftEmpty && rightEmpty) {
                    flowerbed[i] = 1;  // plant flower
                    n--;               // decrease required flowers

                    // If all flowers are planted, return true
                    if(n == 0)
                        return true;

                    i++; // skip next index (adjacent plot cannot be used)
                }
            }

            i++;
        }

        // If n <= 0, we successfully planted all required flowers
        return n <= 0;
    }
};
